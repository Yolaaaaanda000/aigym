{
  "_说明": "由 Claire 设计填充，引擎只读这里。本次升级：①「场景盲盒抽卡」(contexts + 每动作 tags 按场景过滤)；② 每动作加 protocol(组数/节奏)，做完所有组才算完成；③ config.trigger 触发与免打扰参数。新增字段均为增量，老引擎忽略仍可跑。新流程/结构变更详见 design/interaction-spec.md，字段含义见 design/README.md。",

  "goals": {
    "lose": "减脂",
    "strength": "力量",
    "stretch": "拉伸"
  },

  "_contexts说明": "场景 = 一组约束上限。某动作的每个 tag 都 ≤ 该场景的 max 时，才会在这个场景被抽到。tag/max 四个维度都是 0..2，越小越克制：space 空间(0原地/1小范围/2需展开)、noise 声音(0静音/1轻微/2可出声)、social 社死度(0不易察觉/1正常/2随意)、posture 姿势(0坐着/1要站/2要趴躺)。加新场景只在这里加一条。",
  "contexts": {
    "office":  { "label": "🏢 办公室/工位", "max": { "space": 1, "noise": 0, "social": 0, "posture": 1 } },
    "cafe":    { "label": "☕ 咖啡厅/公共", "max": { "space": 0, "noise": 0, "social": 0, "posture": 0 } },
    "home":    { "label": "🏠 家里",        "max": { "space": 2, "noise": 2, "social": 2, "posture": 2 } },
    "hallway": { "label": "🚶 走廊/茶水间", "max": { "space": 1, "noise": 1, "social": 1, "posture": 1 } }
  },

  "config": {
    "defaultGoal": "strength",
    "defaultContext": "office",
    "drawCount": 6,
    "durationSec": 300,
    "deckHint": "抽 一 张 · 动 5 分 钟",
    "timerSub": "动起来，等它跑完不如等你练完",
    "doneText": "完成 ✓ 螃蟹给你比个心"
  },

  "_trigger说明": "触发与免打扰。判定/调度在引擎+宿主侧，这里是可调参数。cooldownMin 两次弹卡最小间隔；dailyCap 每天上限；minWorkMin 至少专注工作多久才弹(短任务不打扰)；quietHours 静默时段[起,止]；snoozeOptions 小睡选项(分钟)。免打扰=手动开关 + 静默时段(v1 不做自动检测)。弹卡方式=直接弹整张卡。",
  "trigger": {
    "cooldownMin": 30,
    "dailyCap": 8,
    "minWorkMin": 10,
    "quietHours": ["22:00", "08:00"],
    "snoozeOptions": [5, 30],
    "dnd": false
  },

  "_doneMessages说明": "完成(做完所有组)时随机展示一条激励语。引擎不写死文案，从这里取。",
  "doneMessages": [
    "动完这一下，螃蟹给你比个心 🦀💗",
    "5 分钟偷回来了，这把心率你赢了",
    "你的颈椎刚发来一条感谢",
    "等它跑完不如等你练完——你做到了",
    "又一张打卡入账，连续记录 +1"
  ],

  "_refuseReasons说明": "拒绝时给用户选的原因。引擎记录所选原因，喂给 AI 调整下次推荐。",
  "refuseReasons": [
    "正忙，这会儿不行",
    "不在状态",
    "这个动作不想做",
    "环境不合适",
    "待会儿再说"
  ],

